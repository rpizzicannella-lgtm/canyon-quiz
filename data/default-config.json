      "id": "PRIORITY_URGENZA_ALTA_SVINC",
      "name": "Urgenza alta su svincolabile: preferisci svincolo",
      "type": "priority",
      "enabled": true,
      "conditions": [
        {
          "field": "situation",
          "op": "eq",
